  background: rgba(255, 255, 255, 0.78);
  border-color: rgba(12, 46, 96, 0.12);
}

body:has(.index-hero) .main_menu.home_menu.menu_fixed .site-header__search-input {
  background: var(--color-bg-light);
}

/* دکمه ارزیابی و CTA — هم‌سبک index-hero__cta-primary */
body:has(.index-hero) .main_menu.home_menu .site-header__eval-btn {
  box-shadow:
    0 10px 26px rgba(12, 46, 96, 0.22),
    0 3px 10px rgba(12, 46, 96, 0.1);
}

body:has(.index-hero) .main_menu.home_menu .site-header__eval-btn:hover,
body:has(.index-hero) .main_menu.home_menu .site-header__eval-btn:focus {
  box-shadow:
    0 14px 32px rgba(12, 46, 96, 0.26),
    0 4px 12px rgba(12, 46, 96, 0.12);
}

body:has(.index-hero) .main_menu.home_menu .site-header__cta {
  border-radius: var(--radius-pill);
  font-weight: 700 !important;
  box-shadow:
    0 10px 26px rgba(12, 46, 96, 0.2),
    0 3px 10px rgba(12, 46, 96, 0.08);
}

body:has(.index-hero) .main_menu.home_menu .site-header__cta:hover {
  transform: translateY(-1px);
  box-shadow:
    0 14px 32px rgba(12, 46, 96, 0.24),
    0 4px 12px rgba(12, 46, 96, 0.1);
}

@media (min-width: 1200px) {
  body:has(.index-hero) .main_menu.home_menu .navbar {
    padding: 12px 0;
  }

  body:has(.index-hero) .main_menu.home_menu .site-header__menu .nav-link,
  body:has(.index-hero) .main_menu.home_menu .site-header__nav-trigger {
    font-size: 12.5px;
    letter-spacing: -0.01em;
  }
}

@media (max-width: 1199.98px) {
  body:has(.index-hero) .main_menu.home_menu:not(.menu_fixed):not(.site-header--menu-open) {
    background: rgba(248, 250, 255, 0.92);
  }

  body:has(.index-hero) .main_menu.home_menu .site-header__icon-btn {
    border-radius: 10px;
  }
}

@media (prefers-reduced-motion: reduce) {
  .site-header__search-form,
  .site-header__search-open,
  .site-header__search-field,
  .site-header__eval-btn {
    transition-duration: 0.01ms !important;
  }
}
