    next_follow_up_at = models.DateTimeField(
        "پیگیری بعدی",
        null=True,
        blank=True,
    )
    created_by = models.ForeignKey(
        "auth.User",
        on_delete=models.SET_NULL,
        null=True,
        blank=True,
        related_name="evaluation_contact_logs",
        verbose_name="ثبت‌کننده",
    )
    created_at = models.DateTimeField("تاریخ ثبت", auto_now_add=True)

    class Meta:
        app_label = "core"
        db_table = "core_evaluation_contact_log"
        verbose_name = "لاگ تماس ارزیابی"
        verbose_name_plural = "لاگ‌های تماس ارزیابی"
        ordering = ["-created_at"]
        indexes = [
            models.Index(fields=["evaluation", "created_at"], name="eval_log_ev_cr_idx"),
            models.Index(fields=["created_at"], name="eval_log_created_idx"),
        ]

    def __str__(self) -> str:
        return f"{self.evaluation_id} — {self.get_contact_result_display()}"

    def save(self, *args, **kwargs):
        super().save(*args, **kwargs)
        self._sync_parent()

    def _sync_parent(self) -> None:
        ev = self.evaluation
        ev.contact_result = self.contact_result
        ev.contacted_at = self.created_at
        ev.follow_up_required = self.follow_up_required
        ev.follow_up_category = self.follow_up_category or ev.follow_up_category
        ev.next_follow_up_at = self.next_follow_up_at

        if self.contact_result == EvaluationRequest.CONTACT_CONVERTED:
            ev.status = EvaluationRequest.STATUS_COMPLETED
            ev.follow_up_required = False
        elif self.contact_result == EvaluationRequest.CONTACT_NOT_INTERESTED:
            ev.status = EvaluationRequest.STATUS_LOST
            ev.follow_up_required = False
        elif self.follow_up_required:
            ev.status = EvaluationRequest.STATUS_FOLLOW_UP
        elif self.contact_result != EvaluationRequest.CONTACT_NOT_YET:
            ev.status = EvaluationRequest.STATUS_CONTACTED

        if self.notes:
            block = f"[{self.created_at:%Y-%m-%d %H:%M}] {self.notes.strip()}"
            if ev.admin_notes:
                ev.admin_notes = f"{block}\n---\n{ev.admin_notes}"
            else:
                ev.admin_notes = block

        ev.save(
            update_fields=[
                "contact_result",
                "contacted_at",
                "follow_up_required",
                "follow_up_category",
                "next_follow_up_at",
                "status",
                "admin_notes",
                "updated_at",
            ]
        )


