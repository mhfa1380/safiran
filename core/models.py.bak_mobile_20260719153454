        return self.title

    def get_absolute_url(self) -> str:
        from django.urls import reverse

        return reverse("blog_detail", kwargs={"slug": self.slug})

    def get_public_url(self) -> str:
        from .bale_notifier import build_site_link

        canonical = (self.canonical_url or "").strip()
        if canonical:
            return build_site_link(canonical)
        return build_site_link(self.get_absolute_url())

    def _compress_featured_image(self):
        """فشرده‌سازی تصویر شاخص تا سقف تقریبی ۷۰۰KB."""
        if not self.image:
            return
        if not hasattr(self.image, "file"):
            return

        self.image.seek(0)
        raw_bytes = self.image.read()
        if not raw_bytes:
            return

        img = Image.open(io.BytesIO(raw_bytes))
        img = ImageOps.exif_transpose(img)
        if img.mode in ("RGBA", "LA", "P"):
            img = img.convert("RGB")

        max_side = 1920
        if max(img.size) > max_side:
            img.thumbnail((max_side, max_side), Image.Resampling.LANCZOS)

        target_size = 700 * 1024
        quality = 85
        min_quality = 35
        step = 5
        output = io.BytesIO()

        while quality >= min_quality:
            output.seek(0)
            output.truncate(0)
            img.save(output, format="JPEG", optimize=True, quality=quality)
            if output.tell() <= target_size:
                break
            quality -= step

        name_root, _ = os.path.splitext(self.image.name or "featured")
        compressed_name = f"{name_root}.jpg"
        self.image.save(
            compressed_name,
            ContentFile(output.getvalue()),
            save=False,
        )

    def save(self, *args, **kwargs):
        if self.image and hasattr(self.image, "file"):
            self._compress_featured_image()
        super().save(*args, **kwargs)


