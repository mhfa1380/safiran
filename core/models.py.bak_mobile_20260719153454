        from django.urls import reverse

        external = (self.external_url or "").strip()
        if external:
            return external
        return reverse("course_details", kwargs={"slug": self.slug})

    def get_course_cta_label(self) -> str:
        if self.uses_external_link():
            label = (self.external_link_label or "").strip()
            return label or "مشاهده دوره"
        return "جزئیات دوره"

    def get_contact_phone(self) -> str:
        """شماره تماس دوره یا مدرس."""
        phone = (self.phone or "").strip()
        if phone:
            return phone
        if self.instructor_id and self.instructor:
            return (self.instructor.phone or "").strip()
        return ""

    def get_meta_title(self) -> str:
        return (self.meta_title or "").strip() or self.title

    def get_meta_description(self) -> str:
        if (self.meta_description or "").strip():
            return self.meta_description.strip()
        text = (self.short_description or "").strip()
        if len(text) > 157:
            return text[:157].rstrip() + "…"
        return text

    def get_features_list(self):
        """لیست ویژگی‌ها (هر خط یک مورد)."""
        if not self.features:
            return []
        return [line.strip() for line in self.features.strip().splitlines() if line.strip()]

    def get_sample_video_embed_url(self):
        """آدرس embed ویدیو برای نمایش در iframe (یوتیوب و آپارات)."""
        if not self.sample_video:
            return ""
        url = self.sample_video.strip()
        if "youtube.com/watch?v=" in url:
            vid = url.split("v=")[-1].split("&")[0]
            return f"https://www.youtube.com/embed/{vid}"
        if "youtu.be/" in url:
            vid = url.split("youtu.be/")[-1].split("?")[0]
            return f"https://www.youtube.com/embed/{vid}"
        if "aparat.com/v/" in url:
            vid = url.rstrip("/").split("/")[-1]
            return f"https://www.aparat.com/video/video/embed/videohash/{vid}/fa/video_id/{vid}"
        return url


