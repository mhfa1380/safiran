        if (self.meta_description or "").strip():
            return self.meta_description.strip()
        text = (self.intro or "").strip()
        if len(text) > 160:
            return text[:157].rstrip() + "…"
        return text

    def get_search_markers(self) -> set[str]:
        """نشانه‌های متنی برای فیلتر محتوای مرتبط با این کشور."""
        markers = {
            self.code.lower(),
            self.name.lower(),
        }
        extra = {
            "canada": {"کانادا", "canada", "canadian"},
            "spain": {"اسپانیا", "spain", "spanish", "اسپانیایی"},
            "china": {"چین", "china", "chinese", "چینی"},
        }
        markers.update(extra.get(self.code, set()))
        for kw in self.get_keywords_list():
            markers.add(kw.lower())
        return markers


