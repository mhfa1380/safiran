    meta_description = models.CharField("توضیح متا (سئو)", max_length=160, blank=True)

    class Meta:
        app_label = "core"
        db_table = "core_faq"
        verbose_name = "سوال متداول"
        verbose_name_plural = "سوالات متداول"
        ordering = ["order", "id"]

    def __str__(self) -> str:
        return self.question[:60] + ("..." if len(self.question) > 60 else "")

    def get_absolute_url(self) -> str:
        from django.urls import reverse

        return reverse("faq_detail", kwargs={"faq_slug": self.slug})

    def has_extended_content(self) -> bool:
        if not self.detail_content:
            return False
        from django.utils.html import strip_tags

        return bool(strip_tags(self.detail_content).strip())

    def get_meta_title(self) -> str:
        return (self.meta_title or "").strip() or self.question

    def get_meta_description(self) -> str:
        if (self.meta_description or "").strip():
            return self.meta_description.strip()
        from django.utils.html import strip_tags

        source = self.detail_content if self.has_extended_content() else self.answer
        text = strip_tags(source or "").strip()
        if len(text) > 157:
            return text[:157].rstrip() + "…"
        return text or self.question

    def get_detail_html(self) -> str:
        if self.has_extended_content():
            return self.detail_content
        return self.answer

    def save(self, *args, **kwargs):
        if not self.slug:
            self.slug = self._build_unique_slug()
        super().save(*args, **kwargs)

    def _build_unique_slug(self) -> str:
        from django.utils.text import slugify

        base = slugify(self.question, allow_unicode=True)[:180]
        if not base:
            base = f"faq-{self.pk or 'new'}"
        slug = base
        n = 1
        qs = FAQ.objects.all()
        if self.pk:
            qs = qs.exclude(pk=self.pk)
        while qs.filter(slug=slug).exists():
            slug = f"{base}-{n}"
            n += 1
        return slug

    def get_keywords_list(self) -> list[str]:
        if not self.search_keywords:
            return []
        return [k.strip() for k in self.search_keywords.replace("،", ",").split(",") if k.strip()]


