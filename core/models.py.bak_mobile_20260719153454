    def get_keywords_list(self) -> list[str]:
        raw = (self.search_keywords or "").replace("،", ",")
        return [k.strip() for k in raw.split(",") if k.strip()]

    def get_meta_title(self) -> str:
        return (self.meta_title or "").strip() or f"{self.person_name} — {self.title}"

    def get_meta_description(self) -> str:
        if (self.meta_description or "").strip():
            return self.meta_description.strip()
        text = (self.description or "").strip()
        return text[:160] if text else self.title

    def has_extended_content(self) -> bool:
        from django.utils.html import strip_tags

        return bool(strip_tags(self.detail_content or "").strip())

    def get_detail_html(self) -> str:
        if self.has_extended_content():
            return self.detail_content
        return f"<p>{self.description}</p>"

    def save(self, *args, **kwargs):
        if not self.slug:
            self.slug = self._build_unique_slug()
        super().save(*args, **kwargs)

    def _build_unique_slug(self) -> str:
        from django.utils.text import slugify

        base = slugify(f"{self.person_name}-{self.title}", allow_unicode=True)[:180]
        if not base:
            import uuid

            base = f"achievement-{uuid.uuid4().hex[:8]}"
        slug = base
        n = 1
        qs = MonthlyAchievement.objects.exclude(pk=self.pk) if self.pk else MonthlyAchievement.objects.all()
        while qs.filter(slug=slug).exists():
            slug = f"{base}-{n}"
            n += 1
        return slug

    def has_video(self) -> bool:
        return bool(self.video_file) or bool((self.video_url or "").strip())

    def get_video_embed_url(self) -> str:
        """تبدیل لینک یوتیوب/آپارات به embed در صورت امکان."""
        url = (self.video_url or "").strip()
        if not url:
            return ""
        if "youtube.com/watch" in url:
            from urllib.parse import parse_qs, urlparse

            parsed = urlparse(url)
            vid = parse_qs(parsed.query).get("v", [None])[0]
            if vid:
                return f"https://www.youtube.com/embed/{vid}"
        if "youtu.be/" in url:
            vid = url.rstrip("/").split("/")[-1].split("?")[0]
            if vid:
                return f"https://www.youtube.com/embed/{vid}"
        if "aparat.com/v/" in url:
            vid = url.rstrip("/").split("/")[-1]
            return f"https://www.aparat.com/video/video/embed/videohash/{vid}/vt/frame"
        if "embed" in url or "iframe" in url:
            return url
        return url


