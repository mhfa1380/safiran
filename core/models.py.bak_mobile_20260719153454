        ]

    def __str__(self) -> str:
        return self.title

    def _compress_cover_image(self) -> None:
        from .image_compression import DEFAULT_MAX_BYTES, compress_image_field_to_jpeg

        if not self.image:
            return
        try:
            if (self.image.name or "").lower().endswith(".jpg") and self.image.size <= DEFAULT_MAX_BYTES:
                return
        except (OSError, ValueError):
            pass
        target = major_image_upload_to(self, "cover.jpg")
        compress_image_field_to_jpeg(self.image, target_name=target)

    def save(self, *args, **kwargs):
        if not self.slug and self.title:
            from django.utils.text import slugify
            import uuid
            base = slugify(self.title, allow_unicode=True) or slugify(self.title, allow_unicode=False)
            self.slug = base if base else f"major-{uuid.uuid4().hex[:8]}"
        if self.image and hasattr(self.image, "file"):
            self._compress_cover_image()
        super().save(*args, **kwargs)

    def get_image_url(self) -> str:
        if self.image:
            return self.image.url
        return ""

    def get_meta_title(self) -> str:
        return (self.meta_title or "").strip() or self.title

    def get_meta_description(self) -> str:
        if (self.meta_description or "").strip():
            return self.meta_description.strip()
        text = (self.short_description or "").strip()
        if len(text) > 157:
            return text[:157].rstrip() + "…"
        return text


