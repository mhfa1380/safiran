    def __str__(self) -> str:
        return f"{self.full_name} - {self.get_target_country_display()}"

    @property
    def referral_display(self) -> str:
        from .referral_source import format_referral_display

        return format_referral_display(
            self.referral_source,
            self.referral_social_platform,
            self.referral_detail,
        )

    @property
    def is_follow_up_overdue(self) -> bool:
        if not self.follow_up_required or not self.next_follow_up_at:
            return False
        from django.utils import timezone

        return self.next_follow_up_at <= timezone.now()

    def get_recommendation_top_line(self) -> str:
        snap = self.recommendation_snapshot or {}
        if not snap.get("has_data"):
            return ""
        top = snap.get("top_pick") or {}
        country = (top.get("country") or {}).get("name", "")
        uni = (top.get("university") or {}).get("name_fa", "")
        major = (top.get("major") or {}).get("title", "")
        if uni:
            return f"{country} — {uni} — {major}"
        if major and country:
            return f"{country} — {major}"
        return country or ""


