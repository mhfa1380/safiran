        return self.title

    def get_display_summary(self) -> str:
        text = (self.short_description or "").strip()
        if text:
            return text
        return (self.description or "").strip()

    def get_highlights_list(self) -> list[str]:
        if not self.highlights:
            return []
        return [line.strip() for line in self.highlights.splitlines() if line.strip()]

    def get_keywords_list(self) -> list[str]:
        if not self.search_keywords:
            return []
        return [k.strip() for k in self.search_keywords.replace("،", ",").split(",") if k.strip()]

    def _generate_slug(self) -> str:
        from django.utils.text import slugify
        import uuid

        base = slugify(self.title, allow_unicode=True)[:180] or f"service-{uuid.uuid4().hex[:8]}"
        slug = base
        n = 1
        qs = Service.objects.all()
        if self.pk:
            qs = qs.exclude(pk=self.pk)
        while qs.filter(slug=slug).exists():
            slug = f"{base}-{n}"
            n += 1
        return slug

    def save(self, *args, **kwargs):
        if not self.slug and self.title:
            self.slug = self._generate_slug()
        super().save(*args, **kwargs)


