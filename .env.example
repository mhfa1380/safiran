# کپی کنید:  copy .env.example .env
# مقادیر حساس (توکن‌ها) را فقط در .env محلی قرار دهید — این فایل در git است.

# --- Django (اجباری برای توسعه محلی) ---
DJANGO_DEBUG=1
DJANGO_SECRET_KEY=change-me-to-a-long-random-string
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost,saroshan.ir,www.saroshan.ir
DJANGO_CSRF_TRUSTED_ORIGINS=http://127.0.0.1:8000,http://localhost:8000,https://saroshan.ir,https://www.saroshan.ir

# --- سایت ---
SITE_ID=1
# در لوکال:
SITE_URL=http://127.0.0.1:8000
# در production:
# SITE_URL=https://www.saroshan.ir

# --- دیتابیس (پیش‌فرض: SQLite در ریشه پروژه) ---
DB_ENGINE=django.db.backends.sqlite3
# DB_NAME=
# DB_USER=
# DB_PASSWORD=
# DB_HOST=
# DB_PORT=
# DB_CONN_MAX_AGE=60
# DB_SQLITE_TIMEOUT=30

# --- کش (locmem | redis) ---
# لوکال: locmem — سرور production با چند worker گونیکورن: redis
DJANGO_CACHE_BACKEND=locmem
# REDIS_URL=redis://127.0.0.1:6379/1
# CACHE_KEY_PREFIX=safiran
# SESSION_CACHE_REDIS=1

# --- Celery (کارهای پس‌زمینه — فقط روی سرور با worker) ---
CELERY_ENABLED=0
# CELERY_BROKER_URL=redis://127.0.0.1:6379/0
# CELERY_RESULT_BACKEND=redis://127.0.0.1:6379/2
# CELERY_WORKER_PREFETCH=1

# --- بهینه‌سازی production (با DJANGO_DEBUG=0) ---
# WHITENOISE_MAX_AGE=31536000
# PAGE_CACHE_SECONDS=180

# --- اعلان بله ---
BALE_BOT_TOKEN=
# فرم‌ها (ارزیابی، مشاوره، تماس با ما)
BALE_CHAT_ID=
# اپدیت وبلاگ (اگر خالی باشد همان BALE_CHAT_ID)
BALE_BLOG_CHAT_ID=
BALE_TIMEOUT_SECONDS=8
BALE_NOTIFY_BLOG_SAVES=true

# --- پنل MHFA Live (اختیاری) ---
MHFA_LIVE_ENABLED=0
MHFA_PANEL_URL=https://live.mhfa.ir
MHFA_SITE_SLUG=saroshan
MHFA_AGENT_TOKEN=
MHFA_INBOX_TOKEN=
# اعلان هنگام افزودن/ویرایش پست وبلاگ — از طریق پنل لایو (نه بله مستقیم)
MHFA_NOTIFY_BLOG_SAVES=true
MHFA_FOOTER_ENABLED=0
MHFA_FOOTER_KEY=default
MHFA_FOOTER_CACHE_SECONDS=86400
MHFA_FOOTER_FETCH_TIMEOUT_SECONDS=2
MHFA_LIVE_TIMEOUT_SECONDS=8

# --- پنل AI (Xiaomi MiMo) ---
PANEL_AI_ENABLED=1
MIMO_API_KEY=
MIMO_BASE_URL=https://api.xiaomimimo.com/v1
MIMO_MODEL=mimo-v2.5-pro
MIMO_TIMEOUT_SECONDS=30

# --- سئو ---
SEO_SITEMAP_PING_ENABLED=0

# --- نرخ ارز تعرفه (تومان) — اختیاری ---
# RATE_USD_TOMAN=100000
# RATE_EUR_TOMAN=110000

# ============================================================
# production — این بلوک را در .env سرور کپی/فعال کنید
# ============================================================
# DJANGO_DEBUG=0
# DJANGO_CACHE_BACKEND=redis
# REDIS_URL=redis://127.0.0.1:6379/1
# CACHE_KEY_PREFIX=safiran
# SESSION_CACHE_REDIS=1
# CELERY_ENABLED=1
# CELERY_BROKER_URL=redis://127.0.0.1:6379/0
# CELERY_RESULT_BACKEND=redis://127.0.0.1:6379/2
# WHITENOISE_MAX_AGE=31536000
