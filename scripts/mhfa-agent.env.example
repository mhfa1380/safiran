# Copy to /etc/mhfa-agent/saroshan.env on the production server
MHFA_PANEL_URL=https://live.mhfa.ir
MHFA_SITE_SLUG=saroshan
MHFA_AGENT_TOKEN=PASTE_TOKEN_FROM_LIVE_PANEL_ONCE

MHFA_HEARTBEAT_SECONDS=30
MHFA_POLL_COMMAND_SECONDS=5
MHFA_PANEL_PING_SECONDS=300
MHFA_SYSTEMD_UNIT=gunicorn-saroshan.service
